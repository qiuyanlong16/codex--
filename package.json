{
  "name": "by-claw-nanobot",
  "version": "0.1.0",
  "private": true,
  "description": "by-claw-nanobot desktop product - nanobot AI agent integration",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22.16.0",
    "pnpm": ">=9.0.0"
  },
  "lint-staged": {
    "*.{json,md,yml,yaml}": "prettier --write"
  },
  "scripts": {
    "dev": "node scripts/dev/run-dev.mjs",
    "dev:web": "pnpm --filter @byclaw-nanobot/web dev",
    "dev:shell": "pnpm --filter @byclaw-nanobot/shell dev",
    "dev:electron": "pnpm --filter @byclaw-nanobot/shell dev:electron",
    "build:shared": "pnpm --filter @byclaw-nanobot/shared build",
    "build:web": "pnpm --filter @byclaw-nanobot/web build",
    "build:shell": "pnpm --filter @byclaw-nanobot/shell build",
    "build": "pnpm build:shared && pnpm build:web && pnpm build:shell"
  },
  "main": "packages/shell/dist/main/index.js",
  "devDependencies": {
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1"
  }
}